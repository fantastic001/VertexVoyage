    "version": "0.2.0",
    "configurations": [   

        {
            "name": "Python Debugger: Test",
            "type": "debugpy",
            "request": "launch",
            "module": "vertex_voyage.test",
            "env": {
                "FAILFAST": "1",
            }
        },
        {
            "name": "small experiment",
            "type": "debugpy",
            "request": "launch",
            "module": "examples.word2vec"
        }
        {
            "name": "Evaluation",
            "type": "debugpy",
            "request": "launch",
            "module": "vertex_voyage",
            "args": [
                "test",
                "--name",
                "AstroPh",
                "--partitions",
                "1",
                "--break-early",
                "--skip-global"
            ],
            "env": {
                "FAILFAST": "1",
            }
        },
        {
            "name": "Benchmark",
            "type": "debugpy",
            "request": "launch",
            "module": "vertex_voyage.benchmark",
            "args": [
                "Performance comparison max Node2Vec vs lfm on SBM 10M with varying threshold"
            ],
            "env": {
                "VERTEX_VOYAGE_FULL_BENCHMARK": "1",
            }
        }
    ]
}